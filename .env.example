# OpenRouter API Key (gratis, sin tarjeta)
# Obtén la tuya en: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-v1-tu-api-key-aqui

# Anthropic API Key (opcional, alternativa con costo)
# https://console.anthropic.com/keys
VITE_ANTHROPIC_API_KEY=

# Datos de la clínica (se inyectan en el system prompt del agente)
VITE_CLINIC_NAME=Clínica Dental Sonrisa Perfecta
VITE_CLINIC_ADDRESS=Av. Principal 123
VITE_CLINIC_PHONE=+34 900 123 456
VITE_CLINIC_DOCTOR=Dr. Alejandro Martínez
